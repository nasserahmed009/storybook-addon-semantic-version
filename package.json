{
  "name": "storybook-addon-semantic-version",
  "version": "4.0.0",
  "description": "Storybook addon for deploying sematically versioned components",
  "author": "akshay patil",
  "license": "MIT",
  "homepage": "https://github.com/akshayjpatil/storybook-addon-semantic-version?tab=readme-ov-file#storybook-semantic-version-deploy--",
  "repository": {
    "type": "git",
    "url": "https://github.com/akshayjpatil/storybook-addon-semantic-version"
  },
  "storybook": {
    "displayName": "Storybook Semantic Versioning Addon",
    "supportedFrameworks": [
      "react",
      "vue",
      "next",
      "angular",
      "web-components",
      "html",
      "ember",
      "svelte",
      "preact"
    ],
    "icon": "https://github.com/akshayjpatil/storybook-addon-semantic-version/blob/main/assets/logo.png"
  },
  "keywords": [
    "storybook-addons",
    "semver",
    "component",
    "react",
    "typescript",
    "tool",
    "plugin",
    "nx",
    "monorepo"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "dist/register.js",
  "exports": {
    "./preset": {
      "types": "./dist/preset.d.ts",
      "import": "./dist/preset.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "storybook-addon-semantic-version": "./dist/cli/build-storybooks.js"
  },
  "scripts": {
    "prepare": "rollup -c",
    "build": "rollup -c",
    "storybooks:build": "node ./bin/build-storybooks.js",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "storybook": ">=8.0.0 <11.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@storybook/icons": "^1.3.0",
    "chalk": "^5.4.1",
    "semver": "^7.7.4"
  },
  "vitest": {
    "environment": "jsdom",
    "globals": true,
    "setupFiles": [
      "./src/test-setup.ts"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@rollup/plugin-typescript": "^11.1.2",
    "storybook": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.18",
    "@types/react": "^18.0.0",
    "@types/semver": "^7.7.1",
    "@types/yargs": "^17.0.33",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.1",
    "rollup": "^4.0.2",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
